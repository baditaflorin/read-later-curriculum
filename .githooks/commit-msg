#!/usr/bin/env bash
set -euo pipefail

message_file="${1:?commit message file required}"
first_line="$(head -n 1 "$message_file")"

if [[ ! "$first_line" =~ ^(feat|fix|docs|chore|refactor|test|ops|data)(\(.+\))?!?:\ .+ ]]; then
  echo "Commit message must use Conventional Commits." >&2
  echo "Example: feat: build curriculum scheduler" >&2
  exit 1
fi
