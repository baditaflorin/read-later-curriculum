{
  "name": "read-later-curriculum",
  "private": false,
  "version": "0.1.0",
  "description": "A local-first read-later app that turns saved articles into a dependency-ordered reading curriculum.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://baditaflorin.github.io/read-later-curriculum/",
  "repository": {
    "type": "git",
    "url": "https://github.com/baditaflorin/read-later-curriculum.git"
  },
  "bugs": {
    "url": "https://github.com/baditaflorin/read-later-curriculum/issues"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "node scripts/prepare-build.mjs && tsc -b && vite build && node scripts/after-build.mjs",
    "data": "node scripts/generate-sample-data.mjs",
    "lint": "eslint . && prettier --check . && tsc -b --pretty false",
    "fmt": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test-integration": "vitest run --config vitest.integration.config.ts",
    "smoke": "bash scripts/smoke.sh",
    "screenshot": "node scripts/capture-demo.mjs",
    "pages-preview": "node scripts/static-server.mjs docs 4173",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@mozilla/readability": "^0.6.0",
    "@tanstack/react-query": "^5.100.9",
    "dexie": "^4.4.2",
    "fast-xml-parser": "^5.7.3",
    "flexsearch": "^0.8.212",
    "jsonrepair": "^3.14.0",
    "lucide-react": "^1.14.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.5.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.5"
  }
}
